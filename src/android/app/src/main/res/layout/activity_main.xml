<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivVideoLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="video_left"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/ivVideoRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="video_right"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#22000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <FrameLayout
            android:id="@+id/pageContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:id="@+id/pageManual"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="false"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnModeToggle"
                            android:layout_width="104dp"
                            android:layout_height="wrap_content"
                            android:minHeight="34dp"
                            android:text="COMMAND" />

                        <Button
                            android:id="@+id/btnArm"
                            android:layout_width="86dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_oval_button"
                            android:minHeight="34dp"
                            android:text="ARM"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnAltitude"
                            android:layout_width="92dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/bg_oval_button"
                            android:minHeight="34dp"
                            android:text="ALTITUDE"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp" />

                        <Button
                            android:id="@+id/btnPosition"
                            android:layout_width="92dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/bg_oval_button"
                            android:minHeight="34dp"
                            android:text="POSITION"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp" />

                        <Button
                            android:id="@+id/btnOffboard"
                            android:layout_width="94dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/bg_oval_button"
                            android:minHeight="34dp"
                            android:text="OFFBOARD"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnHold"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/bg_oval_button"
                            android:minHeight="34dp"
                            android:text="HOLD"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnLand"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/bg_oval_button"
                            android:minHeight="34dp"
                            android:text="LAND"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <com.example.ZControl.JoystickView
                    android:id="@+id/joystickLeft"
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.65" />

                <com.example.ZControl.JoystickView
                    android:id="@+id/joystickRight"
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.65" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/pageCommand"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnModeToggleCommand"
                        android:layout_width="104dp"
                        android:layout_height="wrap_content"
                        android:minHeight="34dp"
                        android:text="MANUAL" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="260dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:background="#66FFFFFF"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnToggleSlam"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minHeight="32dp"
                            android:text="VIO"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnToggleCalib"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:minHeight="32dp"
                            android:text="Calib"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnCleanCalib"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="32dp"
                        android:text="Clean Calib"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etVehicleIp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Vehicle IP"
                            android:inputType="textUri"
                            android:minHeight="32dp"
                            android:padding="4dp"
                            android:text="192.168.0.103"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etCfgExposure"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Exposure us"
                            android:inputType="number"
                            android:minHeight="32dp"
                            android:padding="4dp"
                            android:text="6000"
                            android:textSize="10sp" />

                        <EditText
                            android:id="@+id/etCfgGain"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:hint="Gain"
                            android:inputType="numberDecimal|numberSigned"
                            android:minHeight="32dp"
                            android:padding="4dp"
                            android:text="4"
                            android:textSize="10sp" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="6dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="300dp"
            android:text="cm5udp ready"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvPose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxWidth="360dp"
            android:text="Pose idle"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvVideoStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxWidth="360dp"
            android:text="Video idle"
            android:textColor="#B3FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvJoystickState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxWidth="300dp"
            android:text="Joystick idle"
            android:textColor="#DDFFFFFF"
            android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
